{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["displayName", "rbac", "tenants", "customer"],
  "properties": {
    "organizationName": {
      "type": "string",
      "maxLength": 63,
      "pattern": "^$|^[a-z][a-z0-9-]{0,61}[a-z0-9]$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63
    },
    "rbac": {
      "type": "object",
      "additionalProperties": false,
      "required": ["admins", "editors", "viewers"],
      "properties": {
        "admins": {
          "type": "array",
          "minItems": 0,
          "maxItems": 50,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 95,
            "pattern": "^[a-z0-9][a-z0-9-]{0,30}:[a-z0-9][a-z0-9._-]{0,62}$"
          }
        },
        "editors": {
          "type": "array",
          "maxItems": 100,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 95,
            "pattern": "^[a-z0-9][a-z0-9-]{0,30}:[a-z0-9][a-z0-9._-]{0,62}$"
          }
        },
        "viewers": {
          "type": "array",
          "maxItems": 100,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 95,
            "pattern": "^[a-z0-9][a-z0-9-]{0,30}:[a-z0-9][a-z0-9._-]{0,62}$"
          }
        }
      }
    },
    "tenants": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "types"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 63,
            "pattern": "^[a-z][a-z0-9-]{0,62}$"
          },
          "types": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": ["data", "alerting"]
            }
          }
        }
      }
    },
    "customer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowedRoles"],
      "properties": {
        "allowedRoles": {
          "type": "array",
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["admins", "editors", "viewers"]
          }
        },
        "configMapName": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*$"
        }
      }
    }
  }
}
